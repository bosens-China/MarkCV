# https://editorconfig.org
root = true

# 通用配置
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# JavaScript / TypeScript
[*.{js,jsx,ts,tsx}]
indent_size = 2

# Vue 单文件组件
[*.vue]
indent_size = 2

# JSON / 配置文件
[*.{json,jsonc}]
indent_size = 2

# HTML
[*.html]
indent_size = 2

# CSS / 预处理器
[*.{css,scss,sass,less}]
indent_size = 2

# Markdown（保留行尾空格，方便换行）
[*.md]
trim_trailing_whitespace = false

# YAML
[*.{yml,yaml}]
indent_size = 2

# Shell
[*.sh]
indent_style = space
indent_size = 2

# Makefile 必须使用 tab
[Makefile]
indent_style = tab
